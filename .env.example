INVESTOR_APP_NAME=investor
INVESTOR_APP_ENV=development
INVESTOR_APP_SECRET=replace-with-long-random-secret
INVESTOR_DATABASE_URL=postgresql://investor:investor@localhost:5432/investor
INVESTOR_SMTP_HOST=smtp.example.com
INVESTOR_SMTP_PORT=587
INVESTOR_SMTP_USERNAME=investor-user
INVESTOR_SMTP_PASSWORD=replace-with-smtp-password
INVESTOR_SMTP_FROM_EMAIL=investor@example.com
INVESTOR_DAILY_MEMO_TO_EMAIL=operator@example.com
INVESTOR_EXTERNAL_BASE_URL=https://investor.example.com
INVESTOR_SCHEDULE_CRON_EXPRESSION=0 7 * * 1-5
INVESTOR_SCHEDULE_TIMEZONE=America/New_York
INVESTOR_SCHEDULE_TRIGGER_URL=http://127.0.0.1:8000/runs/trigger/scheduled
INVESTOR_SCHEDULED_TRIGGER_TOKEN=replace-with-scheduled-trigger-token
INVESTOR_CRON_LOG_PATH=logs/cron/daily-trigger.log
INVESTOR_QUIVER_BASE_URL=https://api.quiverquant.com
INVESTOR_QUIVER_API_KEY=replace-with-quiver-api-key
INVESTOR_BROKER_MODE=paper
INVESTOR_ALPACA_BASE_URL=https://paper-api.alpaca.markets
INVESTOR_ALPACA_API_KEY=replace-with-alpaca-api-key
INVESTOR_OPENAI_API_KEY=replace-with-openai-api-key
INVESTOR_OPENAI_BASE_URL=https://api.openai.com/v1
INVESTOR_OPENAI_MODEL=gpt-4.1-mini
INVESTOR_APPROVAL_TOKEN_TTL_SECONDS=900
